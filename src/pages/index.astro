  .ref-client-list {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 2;
    max-width: 900px;
    margin: 0 auto;
  }

  /* ==================== GALERIE ==================== */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 10px;
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1;
    cursor: pointer;
    border: 1px solid rgba(201, 168, 76, 0.1);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease, filter 0.5s ease;
    filter: sepia(20%) brightness(0.85);
  }

  .gallery-item:hover img {
    transform: scale(1.1);
    filter: sepia(0%) brightness(1);
  }

  .gallery-item::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(13, 10, 7, 0.3);
    transition: background 0.4s ease;
    pointer-events: none;
  }

  .gallery-item:hover::after {
    background: rgba(13, 10, 7, 0);
  }

  /* ==================== LIGHTBOX ==================== */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 2000;
    background: rgba(0, 0, 0, 0.95);
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .lightbox.active {
    display: flex;
  }

  .lightbox-img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    box-shadow: 0 0 60px rgba(0, 0, 0, 0.5);
  }

  .lightbox-close {
    position: absolute;
    top: 1.5rem;
    right: 2rem;
    font-size: 2.5rem;
    color: var(--color-cream);
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.3s;
    z-index: 10;
  }

  .lightbox-close:hover {
    color: var(--color-gold);
  }

  .lightbox-prev,
  .lightbox-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    font-size: 2rem;
    color: var(--color-cream);
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(201, 168, 76, 0.2);
    cursor: pointer;
    padding: 0.8rem 1.2rem;
    transition: background 0.3s, color 0.3s;
    z-index: 10;
  }

  .lightbox-prev { left: 1rem; }
  .lightbox-next { right: 1rem; }

  .lightbox-prev:hover,
  .lightbox-next:hover {
    background: rgba(201, 168, 76, 0.15);
    color: var(--color-gold);
  }

  /* ==================== MÉDIAS ==================== */
  .medias-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    max-width: 800px;
    margin: 0 auto 3rem;
  }

  .media-item h3 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--color-gold);
    margin-bottom: 0.3rem;
  }

  .media-item > p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 1rem;
    font-style: italic;
  }

  .video-wrap {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border: 1px solid rgba(201, 168, 76, 0.15);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
  }

  .video-wrap iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .media-photo {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .media-photo img {
    border: 1px solid rgba(201, 168, 76, 0.15);
    padding: 4px;
    margin: 0 auto;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
  }

  .media-photo p {
    margin-top: 1rem;
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  /* ==================== CONTACT ==================== */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: start;
  }

  .contact-card img {
    border: 1px solid rgba(201, 168, 76, 0.2);
    padding: 4px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
    margin-bottom: 1.5rem;
  }

  .contact-invite {
    font-size: 1rem;
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--color-gold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .form-group input,
  .form-group textarea {
    background: rgba(26, 21, 16, 0.8);
    border: 1px solid rgba(201, 168, 76, 0.2);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.8rem 1rem;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
    outline: none;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--color-gold);
    box-shadow: 0 0 15px rgba(201, 168, 76, 0.1);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 140px;
  }

  .btn-submit {
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-cream);
    background: transparent;
    border: 1px solid var(--color-gold);
    padding: 0.9rem 2.5rem;
    cursor: pointer;
    transition: background 0.4s ease, color 0.4s ease, box-shadow 0.4s ease;
    align-self: flex-start;
  }

  .btn-submit:hover {
    background: var(--color-gold);
    color: var(--color-bg);
    box-shadow: 0 4px 20px rgba(201, 168, 76, 0.3);
  }

  /* ==================== FOOTER ==================== */
  .site-footer {
    text-align: center;
    padding: 3rem 2rem;
    border-top: 1px solid rgba(201, 168, 76, 0.1);
    background: var(--color-bg);
  }

  .footer-ornament {
    color: var(--color-gold-dark);
    font-size: 1.2rem;
    margin-bottom: 1rem;
    opacity: 0.4;
  }

  .footer-name {
    font-family: var(--font-display);
    color: var(--color-gold);
    font-size: 1.1rem;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .footer-credits {
    font-size: 0.8rem;
  }

  .footer-credits a {
