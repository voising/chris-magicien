---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const siteUrl = 'https://www.chris-magicien.fr';
const ogImage = `${siteUrl}/images/gala.webp`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: siteUrl,
      name: "Chris — Magicien de la Belle Époque",
      description,
      inLanguage: "fr-FR",
    },
    {
      "@type": "LocalBusiness",
      "@id": `${siteUrl}/#business`,
      name: "Chris Magicien de la Belle Époque",
      description: "Magicien professionnel à Rennes en Bretagne. Prestations de magie close up, cocktail, salon et scène pour particuliers et entreprises.",
      url: siteUrl,
      image: ogImage,
      telephone: "",
      address: {
        "@type": "PostalAddress",
        addressLocality: "Rennes",
        addressRegion: "Bretagne",
        addressCountry: "FR",
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: 48.1173,
        longitude: -1.6778,
      },
      areaServed: [
        { "@type": "State", name: "Bretagne" },
        { "@type": "State", name: "Pays de la Loire" },
        { "@type": "Country", name: "France" },
      ],
      priceRange: "$$",
      knowsAbout: ["Magie close up", "Magie de salon", "Spectacle de scène", "Magie cocktail", "Mentalisme"],
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      name: "Chris",
      jobTitle: "Magicien professionnel",
      description: "Artiste illusionniste de la Belle Époque, personnage à la croisée des chemins entre Arsène Lupin et Sherlock Holmes.",
      url: siteUrl,
      image: `${siteUrl}/images/portrait.webp`,
      sameAs: [
        "https://www.youtube.com/channel/UCfKq0dSfAmkiqf4l8yVmr0A",
      ],
      award: "Prix du Public — Festival des Stars de la Magie et des Étoiles du Cirque 2020",
    },
    {
      "@type": "WebPage",
      "@id": `${siteUrl}/#webpage`,
      url: siteUrl,
      name: title,
      isPartOf: { "@id": `${siteUrl}/#website` },
      about: { "@id": `${siteUrl}/#person` },
      description,
      inLanguage: "fr-FR",
    },
  ],
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="magicien rennes, magicien bretagne, magie close up rennes, magicien mariage rennes, magicien événementiel bretagne, spectacle magie belle époque, magicien professionnel ille et vilaine, close up magie, magicien animation entreprise, magicien cocktail" />
    <link rel="canonical" href={siteUrl} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Chris — Magicien de la Belle Époque" />
    <meta name="geo.region" content="FR-35" />
    <meta name="geo.placename" content="Rennes" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="683" />
    <meta property="og:image:alt" content="Chris Magicien de la Belle Époque en prestation" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Chris — Magicien de la Belle Époque" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Chris Magicien de la Belle Époque en prestation" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Fonts (non-render-blocking) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
    </noscript>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --color-bg: #0D0A07;
    --color-bg-alt: #1A1510;
    --color-bg-section: #13100B;
    --color-cream: #F5EFE0;
    --color-cream-soft: #E8DFD0;
    --color-gold: #C9A84C;
    --color-gold-light: #E0C872;
    --color-gold-dark: #8B7331;
    --color-burgundy: #6B1D2A;
    --color-burgundy-light: #8B2E3C;
    --color-text: #D4CBBA;
    --color-text-light: #F5EFE0;
    --color-text-muted: #8A7E6E;

    --font-display: 'Playfair Display', Georgia, serif;
    --font-body: 'Cormorant Garamond', 'Times New Roman', serif;
    --font-accent: 'Lora', Georgia, serif;

    --max-width: 1200px;
    --section-padding: 6rem 2rem;
  }

  html {
    scroll-behavior: smooth;
    font-size: 18px;
  }

  body {
    font-family: var(--font-body);
    background-color: var(--color-bg);
    color: var(--color-text);
    line-height: 1.7;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  a {
    color: var(--color-gold);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  a:hover {
    color: var(--color-gold-light);
  }

  h1, h2, h3, h4 {
    font-family: var(--font-display);
    color: var(--color-cream);
    font-weight: 400;
  }

  .section {
    padding: var(--section-padding);
    position: relative;
  }

  .section-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    text-align: center;
    font-size: 2.5rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    color: var(--color-gold);
  }

  .ornament {
    display: block;
    text-align: center;
    margin: 0 auto 3rem;
    color: var(--color-gold-dark);
    font-size: 1.5rem;
    letter-spacing: 0.5em;
    opacity: 0.6;
  }

  .ornament::before {
    content: '\2014\00a0\2726\00a0\2014';
  }

  /* Fade-in animation */
  .fade-in {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    html {
      font-size: 16px;
    }

    :root {
      --section-padding: 4rem 1.25rem;
    }

    .section-title {
      font-size: 1.8rem;
    }
  }
</style>
